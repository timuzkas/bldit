# ── ansi styling ──

C = lambda code, text: f"\033[{code}m{text}\033[0m"
DIM = lambda t: C("2", t)
BOLD = lambda t: C("1", t)
GREEN = lambda t: C("32", t)
CYAN = lambda t: C("36", t)
YELLOW = lambda t: C("33", t)
RED = lambda t: C("31", t)
BLUE = lambda t: C("34", t)
MAGENTA = lambda t: C("35", t)
DIM_GREEN = lambda t: C("2;32", t)

SPIN = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"

def strip_md(text):
    text = re.sub(r'\*\*(.+?)\*\*', r'\1', text)
    text = re.sub(r'`(.+?)`', r'\1', text)
    text = re.sub(r'^###?\s+', '', text, flags=re.MULTILINE)
    return text.strip()

# ── config ──

def load_config():
    cfg = dict(DEFAULT_CONFIG)
    try:
        if CONFIG_FILE.exists():
            loaded = json.loads(CONFIG_FILE.read_text())
            cfg.update(loaded)
    except Exception:
        pass
    return cfg

def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

# ── helpers ──

def os_context():
    info = {}
    try:
        with open("/etc/os-release") as f:
            for line in f:
                if "=" in line:
                    k, v = line.strip().split("=", 1)
                    info[k] = v.strip("\"'")
    except Exception:
        pass
    os_id = info.get("ID", "linux")
    ver = info.get("VERSION_ID", "")
    try:
        shell = os.path.basename(os.environ.get("SHELL", "unknown"))
    except Exception:
        shell = "unknown"
    return f"OS: {os_id} {ver}, Shell: {shell}"

def read_readme(repo_dir):
    for name in ("README.md", "README.txt", "README", "readme.md", "README.rst", "INSTALL.md"):
        p = Path(repo_dir) / name
        if p.exists():
            return p.read_text(errors="replace")[:10000]
    return "(no README found)"

def file_tree(repo_dir, max_lines=80):
    try:
        r = subprocess.run(
            ["find", repo_dir, "-maxdepth", "3", "-not", "-path", "*/venv/*",
             "-not", "-path", "*/node_modules/*", "-not", "-path", "*/.git/*",
             "-not", "-path", "*/__pycache__/*", "-not", "-path", "*/build/*",
             "-not", "-path", "*/dist/*", "-not", "-path", "*/target/*",
             "-not", "-path", "*/vendor/*", "-not", "-path", "*/CMakeFiles/*"],
            capture_output=True, text=True, timeout=10
        )
        lines = [l.replace(repo_dir, ".").strip() for l in r.stdout.split("\n") if l.strip()]
        lines.sort()
        if len(lines) > max_lines:
            lines = lines[:max_lines] + [f"... ({len(lines) - max_lines} more)"]
        return "\n".join(lines) if lines else "(empty)"
    except Exception as e:
        return f"(error: {e})"

# ── spinner ──

class Spinner:
    def __init__(self):
        self._stop = False
        self._msg = ""
        self._thread = None

    def start(self, msg="working"):
        self._msg = msg
        self._stop = False
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()

    def message(self, msg):
        self._msg = msg

    def stop(self):
        self._stop = True
        if self._thread:
            self._thread.join(timeout=0.5)
        sys.stdout.write("\r" + " " * shutil.get_terminal_size().columns + "\r")
        sys.stdout.flush()

    def _run(self):
        i = 0
        while not self._stop:
            ch = SPIN[i % len(SPIN)]
            sys.stdout.write(f"\r  {BLUE(ch)} {DIM(self._msg)}")
            sys.stdout.flush()
            time.sleep(0.08)
            i += 1

# ── server ──

class ServerManager:
    def __init__(self, cfg):
        self.base_url = cfg["base_url"].rstrip("/")
        self.headers = {}
        if cfg.get("api_key"):
            self.headers["Authorization"] = f"Bearer {cfg['api_key']}"

    def is_running(self):
        try:
            r = requests.get(f"{self.base_url}/models", timeout=3, headers=self.headers)
            return r.ok
        except Exception:
            return False

    def start(self, model):
        port = 8080
        m = re.search(r":(\d+)", self.base_url)
        if m:
            port = int(m.group(1))
        cmd = ["llama-server", "-hf", model, "--port", str(port)]
        try:
            subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            t0 = time.time()
            while time.time() - t0 < 90:
                if self.is_running():
                    return True
                time.sleep(1)
            return False
        except FileNotFoundError:
            return False

# ── llm ──

class LLM:
    def __init__(self, cfg):
        self.base_url = cfg["base_url"].rstrip("/")
        self.model = cfg.get("model")
        self.headers = {}
        if cfg.get("api_key"):
            self.headers["Authorization"] = f"Bearer {cfg['api_key']}"

    def chat_stream(self, messages, tools=None, temperature=0.3, status=""):
        payload = {
            "messages": messages,
            "stream": True,
            "temperature": temperature,
        }
        if self.model:
            payload["model"] = self.model
        if tools:
            payload["tools"] = tools

        resp = requests.post(
            f"{self.base_url}/chat/completions",
            json=payload, stream=True, timeout=180,
            headers=self.headers,
        )
        resp.raise_for_status()

        content = ""
        tool_calls = []
        finish_reason = "stop"
        spinner = Spinner()
        spinner.start(status or "thinking")
        started = False

        for line in resp.iter_lines():
            if not line:
                continue
            decoded = line.decode("utf-8").strip()
            if not decoded.startswith("data: ") or decoded == "data: [DONE]":
                continue
            data = json.loads(decoded[6:])
            choices = data.get("choices", [])
            if not choices:
                continue
            delta = choices[0].get("delta", {})
            fr = choices[0].get("finish_reason")
            if fr:
                finish_reason = fr

            chunk = delta.get("content", "")
            has_tc = "tool_calls" in delta

            if chunk or has_tc:
                if not started:
                    spinner.stop()
                    started = True
                if chunk:
                    content += chunk

            if has_tc:
                for tc in delta["tool_calls"]:
                    idx = tc.get("index", 0)
                    while len(tool_calls) <= idx:
                        tool_calls.append({
                            "id": "", "type": "function",
                            "function": {"name": "", "arguments": ""}
                        })
                    if "id" in tc:
                        tool_calls[idx]["id"] += tc["id"]
                    if "function" in tc:
                        if "name" in tc["function"]:
                            tool_calls[idx]["function"]["name"] += tc["function"]["name"]
                        if "arguments" in tc["function"]:
                            tool_calls[idx]["function"]["arguments"] += tc["function"]["arguments"]

        if not started:
            spinner.stop()

        return {"content": content, "tool_calls": tool_calls, "finish_reason": finish_reason}

